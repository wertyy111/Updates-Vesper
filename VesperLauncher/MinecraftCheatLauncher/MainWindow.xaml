                                                                <Setter TargetName="SettingsInputBottomRim" Property="Opacity" Value="0.05"/>
                                                                <Setter Property="Effect" Value="{StaticResource GlassButtonShadowHover}"/>
                                                            </Trigger>
                                                            <Trigger Property="IsKeyboardFocused" Value="True">
                                                                <Setter TargetName="SettingsInputBorder" Property="BorderBrush" Value="{StaticResource GlassButtonBorderHoverBrush}"/>
                                                                <Setter TargetName="SettingsInputStableTint" Property="Background" Value="{StaticResource StableDayControlSurfaceHoverBrush}"/>
                                                                <Setter TargetName="SettingsInputShine" Property="Opacity" Value="0.06"/>
                                                                <Setter TargetName="SettingsInputLens" Property="Opacity" Value="0.2"/>
                                                                <Setter TargetName="SettingsInputRefraction" Property="Opacity" Value="0.15"/>
                                                                <Setter TargetName="SettingsInputTopEdge" Property="Opacity" Value="0.18"/>
                                                                <Setter TargetName="SettingsInputBottomRim" Property="Opacity" Value="0.06"/>
                                                                <Setter Property="Effect" Value="{StaticResource GlassButtonShadowHover}"/>
                                                            </Trigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter TargetName="SettingsInputBorder" Property="Opacity" Value="0.55"/>
                                                                <Setter Property="Effect" Value="{x:Null}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                        <Style x:Key="LauncherSettingsComboBoxStyle"
                                               TargetType="ComboBox"
                                               BasedOn="{StaticResource LiquidGlassComboBoxStyle}">
                                            <Setter Property="Background" Value="#24000000"/>
                                            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
