                                                                    BorderThickness="0.5"
                                                                    BorderBrush="{StaticResource GlassButtonTopEdgeBrush}"
                                                                    Opacity="0.08"/>
                                                            <Border x:Name="SettingsComboBoxBottomRim"
                                                                    Margin="2"
                                                                    IsHitTestVisible="False"
                                                                    CornerRadius="{StaticResource LauncherSettingsControlRimCornerRadius}"
                                                                    BorderThickness="0.5"
                                                                    BorderBrush="{StaticResource GlassButtonBottomRimBrush}"
                                                                    Opacity="0.04"/>
                                                            <Grid Margin="{TemplateBinding Padding}">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <ContentPresenter x:Name="ComboBoxContentPresenter"
                                                                                  Grid.Column="0"
                                                                                  Margin="0,0,10,0"
                                                                                  VerticalAlignment="Center"
                                                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                                                  RecognizesAccessKey="True"/>
                                                                <TextBlock Grid.Column="1"
                                                                           VerticalAlignment="Center"
                                                                           FontFamily="Segoe MDL2 Assets"
                                                                           FontSize="12"
                                                                           Foreground="#E8E0CF"
                                                                           Text="&#xE70D;"/>
                                                            </Grid>
                                                            <Popup x:Name="Popup"
                                                                   Placement="Bottom"
                                                                   HorizontalOffset="0"
                                                                   VerticalOffset="0"
                                                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                                                   AllowsTransparency="True"
                                                                   PopupAnimation="Slide"
                                                                   Focusable="False">
                                                                <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                                                    <Border x:Name="ComboBoxPopupBorder"
                                                                            Margin="0,6,0,0"
                                                                            Padding="6"
                                                                            CornerRadius="{StaticResource LauncherSettingsControlCornerRadius}"
                                                                            Background="#D61A2631"
                                                                            BorderBrush="#24FFFFFF"
                                                                            BorderThickness="0.65"
                                                                            Effect="{StaticResource GlassButtonShadowHover}">
                                                                        <ScrollViewer SnapsToDevicePixels="True">
                                                                            <ScrollViewer.Background>
                                                                                <SolidColorBrush Color="Transparent"/>
                                                                            </ScrollViewer.Background>
                                                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                                                        </ScrollViewer>
                                                                    </Border>
                                                                </Grid>
