                                                                                        <Setter TargetName="ThumbSurface" Property="Background" Value="#FFFFFF"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Thumb.Template>
                                                                    </Thumb>
                                                                </Track.Thumb>
                                                            </Track>
                                                        </Grid>
                                                        <ControlTemplate.Triggers>
