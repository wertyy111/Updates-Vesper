                                                                                Orientation="Horizontal">
                                                                        <Button MinWidth="78"
                                                                                Height="28"
                                                                                Margin="0,0,6,0"
                                                                                HorizontalAlignment="Left"
                                                                                FontSize="12"
                                                                                Click="ConnectToFriendButton_OnClick"
                                                                                Tag="{Binding}"
                                                                                IsEnabled="{Binding CanConnect}"
                                                                                ToolTip="{Binding ConnectTooltip}"
                                                                                ToolTipService.ShowOnDisabled="True"
                                                                                Content="Подключиться">
                                                                            <Button.Style>
                                                                                <Style TargetType="Button" BasedOn="{StaticResource MainButtonStyle}">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding ShowConnectButton}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Button.Style>
                                                                        </Button>
                                                                        <Button MinWidth="72"
                                                                                Height="28"
                                                                                HorizontalAlignment="Left"
                                                                                FontSize="12"
                                                                                Style="{StaticResource SavedUsernamesActionButtonStyle}"
                                                                                Click="RemoveFriendEntryButton_OnClick"
                                                                                Tag="{Binding Username}"
                                                                                ToolTip="Удалить друга"
                                                                                Content="Удалить"/>
                                                                    </WrapPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Border>

                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="IncomingFriendRequestsSectionBorder"
                                            Margin="0,14,0,0"
                                            CornerRadius="14"
                                            Background="#2A101820"
                                            BorderBrush="#2EFFFFFF"
                                            BorderThickness="0.65"
                                            Padding="12">
                                        <StackPanel>
                                            <TextBlock FontSize="17" FontWeight="SemiBold" Text="Входящие заявки"/>
                                            <Border Margin="0,10,0,0"
                                                    CornerRadius="10"
                                                    Background="#180D131A"
                                                    BorderBrush="#20FFFFFF"
                                                    BorderThickness="0.65"
                                                    Padding="5">
                                                <ListBox x:Name="IncomingFriendRequestsListBox"
                                                         Style="{StaticResource GlassListBoxStyle}"
                                                         MinHeight="102"
                                                         MaxHeight="200"
                                                         BorderThickness="0"
                                                         Background="Transparent"
                                                         Foreground="#EAF4FF"
                                                         PreviewMouseWheel="ScrollableChild_OnPreviewMouseWheel"
                                                         ScrollViewer.CanContentScroll="False"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                         SelectionChanged="IncomingFriendRequestsListBox_OnSelectionChanged">
                                                    <ListBox.ItemContainerStyle>
                                                        <Style TargetType="ListBoxItem">
                                                            <Setter Property="OverridesDefaultStyle" Value="True"/>
                                                            <Setter Property="Padding" Value="0"/>
                                                            <Setter Property="Margin" Value="0,0,0,5"/>
                                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                            <Setter Property="Focusable" Value="False"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ListBoxItem">
                                                                        <Border x:Name="IncomingRequestItemRoot"
                                                                                Background="Transparent"
                                                                                BorderBrush="Transparent"
                                                                                BorderThickness="0"
                                                                                Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="IncomingRequestItemRoot" Property="Panel.ZIndex" Value="2"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsSelected" Value="True">
                                                                                <Setter TargetName="IncomingRequestItemRoot" Property="Panel.ZIndex" Value="3"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsEnabled" Value="False">
                                                                                <Setter TargetName="IncomingRequestItemRoot" Property="Opacity" Value="0.58"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </ListBox.ItemContainerStyle>
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Padding="7"
                                                                    CornerRadius="12"
                                                                    Background="#1A0E151C"
                                                                    BorderBrush="#18FFFFFF"
                                                                    BorderThickness="0.65">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="8"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>

                                                                    <Border Width="34"
                                                                            Height="34"
                                                                            CornerRadius="10"
                                                                            Background="#2A17212C"
                                                                            BorderBrush="#28FFFFFF"
                                                                            BorderThickness="0.65">
                                                                        <Grid>
                                                                            <Image Source="{Binding AvatarImage}"
                                                                                   Clip="M0,9 C0,4.029 4.029,0 9,0 L25,0 C29.971,0 34,4.029 34,9 L34,25 C34,29.971 29.971,34 25,34 L9,34 C4.029,34 0,29.971 0,25 Z"
                                                                                   Stretch="UniformToFill"
                                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                            <TextBlock HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"
                                                                                       FontSize="10"
                                                                                       FontWeight="SemiBold"
                                                                                       Foreground="#DDF1FF"
                                                                                       Text="{Binding AvatarPlaceholder}">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding AvatarImage}" Value="{x:Null}">
                                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                        </Grid>
                                                                    </Border>

                                                                    <StackPanel Grid.Column="2"
                                                                                VerticalAlignment="Center">
                                                                        <TextBlock FontSize="13"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="#F1F7FF"
                                                                                   Text="{Binding Username}"/>
                                                                        <TextBlock Margin="0,3,0,0"
                                                                                   FontSize="11"
                                                                                   Foreground="#A9C4DA"
                                                                                   Text="{Binding SubtitleText}"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Border>
                                            <Grid x:Name="IncomingFriendRequestsActionGrid" Margin="0,12,0,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition x:Name="IncomingFriendRequestsActionTopRow" Height="Auto"/>
                                                    <RowDefinition x:Name="IncomingFriendRequestsActionGapRow" Height="0"/>
                                                    <RowDefinition x:Name="IncomingFriendRequestsActionBottomRow" Height="0"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition x:Name="IncomingFriendRequestsActionLeftColumn" Width="*"/>
                                                    <ColumnDefinition x:Name="IncomingFriendRequestsActionGapColumn" Width="10"/>
                                                    <ColumnDefinition x:Name="IncomingFriendRequestsActionRightColumn" Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button x:Name="AcceptFriendRequestButton"
                                                        Grid.Row="0"
                                                        Grid.Column="0"
                                                        Height="40"
                                                        Style="{StaticResource MainButtonStyle}"
                                                        Click="AcceptFriendRequestButton_OnClick"
                                                        Content="Принять заявку"/>
                                                <Button x:Name="DeclineFriendRequestButton"
                                                        Grid.Row="0"
                                                        Grid.Column="2"
                                                        Height="40"
                                                        Style="{StaticResource MainButtonStyle}"
                                                        Click="DeclineFriendRequestButton_OnClick"
                                                        Content="Отклонить"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border x:Name="BottomActionBarBorder"
                            Grid.Row="1"
                            Grid.ColumnSpan="2"
                            HorizontalAlignment="Stretch"
                             Margin="0,16,0,0"
                             CornerRadius="16"
                             Background="{StaticResource StableDayPanelSurfaceBrush}"
                             BorderBrush="#24FFFFFF"
                             BorderThickness="0.65,0.65,0.65,0.2"
                            Padding="0">
                        <Grid>
                            <Border Margin="1"
                                    CornerRadius="15"
                                    IsHitTestVisible="False"
                                    Background="{StaticResource GlassPanelSurfaceWashBrush}"/>
                            <Border Margin="1"
                                    CornerRadius="15"
                                    IsHitTestVisible="False"
                                    BorderBrush="{StaticResource GlassPanelInnerEdgeBrush}"
                                    BorderThickness="0.45"
                                    Opacity="0.5"/>
                            <Border Margin="1"
                                    CornerRadius="15"
                                    IsHitTestVisible="False"
                                    Background="{StaticResource GlassPanelSoftLensBrush}"
                                    Opacity="0.18"/>
                        <UniformGrid Rows="1" Columns="4" Margin="10">
                            <Button x:Name="SkinButton"
                                    Margin="4,0"
                                    Height="44"
                                    MinWidth="120"
                                    Style="{StaticResource MainButtonStyle}"
                                    Click="SkinButton_OnClick"
                                    Content="Скин"/>
                            <Button x:Name="BackgroundButton"
                                    Margin="4,0"
                                    Height="44"
                                    MinWidth="120"
                                    Style="{StaticResource MainButtonStyle}"
                                    Click="BackgroundButton_OnClick"
                                    Content="Фон"/>
                            <Button x:Name="ModsButton"
                                    Margin="4,0"
                                    Height="44"
                                    MinWidth="120"
                                    Style="{StaticResource MainButtonStyle}"
                                    Click="ModsButton_OnClick"
                                    Content="Моды"/>
                            <Button x:Name="FriendsButton"
                                    Margin="4,0"
                                    Height="44"
                                    MinWidth="120"
                                    Style="{StaticResource MainButtonStyle}"
                                    Click="FriendsButton_OnClick"
                                    Content="Друзья"/>
                        </UniformGrid>
                        </Grid>
                    </Border>
                </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>



