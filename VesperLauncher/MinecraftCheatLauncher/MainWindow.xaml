<Window x:Class="VesperLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:blur="clr-namespace:BlurredBackground.WPF;assembly=BlurredBackground.WPF"
        xmlns:local="clr-namespace:VesperLauncher"
        mc:Ignorable="d"
        Title="Vesper Launcher"
        Icon="Assets/vesper-app.ico"
        Width="1100"
        Height="720"
        MinWidth="960"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Background="#15110D"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="8"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F2F2F2"/>
        </Style>

        <LinearGradientBrush x:Key="NightBaseBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#0D0B09" Offset="0"/>
            <GradientStop Color="#15110D" Offset="0.45"/>
            <GradientStop Color="#0F0C0A" Offset="1"/>
        </LinearGradientBrush>

        <RadialGradientBrush x:Key="MoonGlowBrush" Center="0.55,0.38" GradientOrigin="0.55,0.38" RadiusX="0.55" RadiusY="0.55">
            <GradientStop Color="#2FFFFFFF" Offset="0"/>
            <GradientStop Color="#12000000" Offset="0.55"/>
            <GradientStop Color="#00000000" Offset="1"/>
        </RadialGradientBrush>

        <RadialGradientBrush x:Key="VignetteBrush" Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.8" RadiusY="0.8">
            <GradientStop Color="#00000000" Offset="0.58"/>
            <GradientStop Color="#72080604" Offset="1"/>
        </RadialGradientBrush>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#262626"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Background="Transparent"
                                          Margin="0"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LiquidGlassTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource GlassButtonBackgroundBrush}"/>
            <Setter Property="Foreground" Value="#F7FBFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource GlassButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0.65"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="IBeam"/>
            <Setter Property="Effect" Value="{StaticResource GlassButtonShadow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="NickInputBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12"/>
                            <Border x:Name="NickInputStableTint"
                                    Margin="1"
                                    IsHitTestVisible="False"
                                    CornerRadius="11"
                                    Background="{StaticResource StableDayControlSurfaceBrush}"/>
                            <Border x:Name="NickInputShine"
                                    Margin="1"
                                    IsHitTestVisible="False"
                                    CornerRadius="11"
                                    Background="{StaticResource GlassButtonShineBrush}"
                                    Opacity="0.03"/>
                            <Border x:Name="NickInputLens"
                                    Margin="1"
                                    IsHitTestVisible="False"
                                    CornerRadius="11"
                                    Background="{StaticResource GlassButtonLensBrush}"
                                    Opacity="0.12"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <SkewTransform AngleX="-7"/>
                                </Border.RenderTransform>
                            </Border>
                            <Border x:Name="NickInputRefraction"
                                    Margin="1"
                                    IsHitTestVisible="False"
                                    CornerRadius="11"
                                    Background="{StaticResource GlassButtonRefractionBrush}"
                                    Opacity="0.09"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1.08" ScaleY="1.03"/>
                                </Border.RenderTransform>
                            </Border>
                            <Border x:Name="NickInputShade"
                                    Margin="1"
                                    IsHitTestVisible="False"
                                    CornerRadius="11"
                                    Background="{StaticResource GlassButtonInnerShadeBrush}"/>
                            <Border x:Name="NickInputReflection"
                                    Margin="1"
                                    IsHitTestVisible="False"
                                    CornerRadius="11"
                                    Background="{StaticResource GlassButtonReflectionBrush}"
                                    Opacity="0.008"/>
                            <Border x:Name="NickInputTopEdge"
                                    Margin="1"
                                    IsHitTestVisible="False"
                                    CornerRadius="11"
                                    BorderThickness="0.5"
                                    BorderBrush="{StaticResource GlassButtonTopEdgeBrush}"
                                    Opacity="0.08"/>
                            <Border x:Name="NickInputBottomRim"
                                    Margin="2"
                                    IsHitTestVisible="False"
                                    CornerRadius="9"
                                    BorderThickness="0.5"
                                    BorderBrush="{StaticResource GlassButtonBottomRimBrush}"
                                    Opacity="0.04"/>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Background="Transparent"
                                          Margin="0"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NickInputBorder" Property="BorderBrush" Value="{StaticResource GlassButtonBorderHoverBrush}"/>
                                <Setter TargetName="NickInputStableTint" Property="Background" Value="{StaticResource StableDayControlSurfaceHoverBrush}"/>
                                <Setter TargetName="NickInputLens" Property="Opacity" Value="0.18"/>
                                <Setter TargetName="NickInputRefraction" Property="Opacity" Value="0.13"/>
                                <Setter TargetName="NickInputTopEdge" Property="Opacity" Value="0.14"/>
                                <Setter TargetName="NickInputBottomRim" Property="Opacity" Value="0.05"/>
                                <Setter Property="Effect" Value="{StaticResource GlassButtonShadowHover}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="NickInputBorder" Property="BorderBrush" Value="{StaticResource GlassButtonBorderHoverBrush}"/>
                                <Setter TargetName="NickInputStableTint" Property="Background" Value="{StaticResource StableDayControlSurfaceHoverBrush}"/>
                                <Setter TargetName="NickInputShine" Property="Opacity" Value="0.06"/>
                                <Setter TargetName="NickInputLens" Property="Opacity" Value="0.2"/>
                                <Setter TargetName="NickInputRefraction" Property="Opacity" Value="0.15"/>
                                <Setter TargetName="NickInputTopEdge" Property="Opacity" Value="0.18"/>
                                <Setter TargetName="NickInputBottomRim" Property="Opacity" Value="0.06"/>
                                <Setter Property="Effect" Value="{StaticResource GlassButtonShadowHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="NickInputBorder" Property="Opacity" Value="0.55"/>
                                <Setter Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CatalogSearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#2A121B26"/>
            <Setter Property="Foreground" Value="#F8FCFF"/>
            <Setter Property="BorderBrush" Value="#46C8DEEF"/>
            <Setter Property="BorderThickness" Value="0.7"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Padding" Value="28,0,14,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="IBeam"/>
            <Setter Property="CaretBrush" Value="#77D9EEFF"/>
            <Setter Property="Effect" Value="{StaticResource GlassButtonShadow}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="SearchBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="14"/>
                            <Border x:Name="SearchTint"
                                    Margin="1"
                                    CornerRadius="13"
                                    IsHitTestVisible="False"
                                    Background="#13233442"/>
                            <Border x:Name="SearchGlow"
                                    Margin="1"
                                    CornerRadius="13"
                                    IsHitTestVisible="False"
                                    Opacity="0.08">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#16D3EEFF" Offset="0"/>
                                        <GradientStop Color="#06D3EEFF" Offset="0.55"/>
                                        <GradientStop Color="#00D5EEFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Border x:Name="SearchTopEdge"
                                    Margin="1"
                                    CornerRadius="13"
                                    IsHitTestVisible="False"
                                    BorderThickness="0.55"
                                    BorderBrush="#79FFFFFF"
                                    Opacity="0.1"/>
                            <Path x:Name="SearchIcon"
                                  Width="12"
                                  Height="12"
                                  Margin="10,0,0,0"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  Stroke="#BFDCEE"
                                  StrokeThickness="1.65"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Stretch="Fill"
                                  Data="M7.1,7.1 L11.2,11.2 M8.7,4.9 A3.8,3.8 0 1 1 1.1,4.9 A3.8,3.8 0 1 1 8.7,4.9 Z"/>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Background="Transparent"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SearchBorder" Property="BorderBrush" Value="#60D8EEFF"/>
                                <Setter TargetName="SearchGlow" Property="Opacity" Value="0.14"/>
                                <Setter TargetName="SearchTopEdge" Property="Opacity" Value="0.16"/>
                                <Setter TargetName="SearchIcon" Property="Stroke" Value="#E6F4FD"/>
                                <Setter Property="Effect" Value="{StaticResource GlassButtonShadowHover}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="SearchBorder" Property="BorderBrush" Value="#71DFF4FF"/>
                                <Setter TargetName="SearchTint" Property="Background" Value="#18283A53"/>
                                <Setter TargetName="SearchGlow" Property="Opacity" Value="0.2"/>
                                <Setter TargetName="SearchTopEdge" Property="Opacity" Value="0.22"/>
                                <Setter TargetName="SearchIcon" Property="Stroke" Value="#F3FCFF"/>
                                <Setter Property="Effect" Value="{StaticResource GlassButtonShadowHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="SearchBorder" Property="Opacity" Value="0.55"/>
                                <Setter TargetName="SearchIcon" Property="Opacity" Value="0.5"/>
                                <Setter Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LiquidGlassPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource GlassButtonBackgroundBrush}"/>
            <Setter Property="Foreground" Value="#F7FBFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource GlassButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0.65"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Effect" Value="{StaticResource GlassButtonShadow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Grid>
                            <Border x:Name="PasswordInputBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12"/>
                            <Border x:Name="PasswordInputStableTint"
                                    Margin="1"
                                    IsHitTestVisible="False"
                                    CornerRadius="11"
                                    Background="{StaticResource StableDayControlSurfaceBrush}"/>
                            <Border x:Name="PasswordInputShine"
                                    Margin="1"
                                    IsHitTestVisible="False"
                                    CornerRadius="11"
                                    Background="{StaticResource GlassButtonShineBrush}"
                                    Opacity="0.03"/>
                            <Border x:Name="PasswordInputLens"
                                    Margin="1"
                                    IsHitTestVisible="False"
                                    CornerRadius="11"
                                    Background="{StaticResource GlassButtonLensBrush}"
                                    Opacity="0.12"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <SkewTransform AngleX="-7"/>
                                </Border.RenderTransform>
                            </Border>
                            <Border x:Name="PasswordInputRefraction"
                                    Margin="1"
                                    IsHitTestVisible="False"
                                    CornerRadius="11"
                                    Background="{StaticResource GlassButtonRefractionBrush}"
                                    Opacity="0.09"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1.08" ScaleY="1.03"/>
                                </Border.RenderTransform>
                            </Border>
                            <Border x:Name="PasswordInputShade"
                                    Margin="1"
                                    IsHitTestVisible="False"
                                    CornerRadius="11"
                                    Background="{StaticResource GlassButtonInnerShadeBrush}"/>
                            <Border x:Name="PasswordInputReflection"
                                    Margin="1"
                                    IsHitTestVisible="False"
                                    CornerRadius="11"
                                    Background="{StaticResource GlassButtonReflectionBrush}"
                                    Opacity="0.008"/>
                            <Border x:Name="PasswordInputTopEdge"
                                    Margin="1"
                                    IsHitTestVisible="False"
                                    CornerRadius="11"
                                    BorderThickness="0.5"
                                    BorderBrush="{StaticResource GlassButtonTopEdgeBrush}"
                                    Opacity="0.08"/>
                            <Border x:Name="PasswordInputBottomRim"
                                    Margin="2"
                                    IsHitTestVisible="False"
                                    CornerRadius="9"
                                    BorderThickness="0.5"
                                    BorderBrush="{StaticResource GlassButtonBottomRimBrush}"
                                    Opacity="0.04"/>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Background="Transparent"
                                          Margin="0"
                                          VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PasswordInputBorder" Property="BorderBrush" Value="{StaticResource GlassButtonBorderHoverBrush}"/>
                                <Setter TargetName="PasswordInputStableTint" Property="Background" Value="{StaticResource StableDayControlSurfaceHoverBrush}"/>
                                <Setter TargetName="PasswordInputLens" Property="Opacity" Value="0.18"/>
                                <Setter TargetName="PasswordInputRefraction" Property="Opacity" Value="0.13"/>
                                <Setter TargetName="PasswordInputTopEdge" Property="Opacity" Value="0.14"/>
                                <Setter TargetName="PasswordInputBottomRim" Property="Opacity" Value="0.05"/>
                                <Setter Property="Effect" Value="{StaticResource GlassButtonShadowHover}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="PasswordInputBorder" Property="BorderBrush" Value="{StaticResource GlassButtonBorderHoverBrush}"/>
                                <Setter TargetName="PasswordInputStableTint" Property="Background" Value="{StaticResource StableDayControlSurfaceHoverBrush}"/>
                                <Setter TargetName="PasswordInputShine" Property="Opacity" Value="0.06"/>
                                <Setter TargetName="PasswordInputLens" Property="Opacity" Value="0.2"/>
                                <Setter TargetName="PasswordInputRefraction" Property="Opacity" Value="0.15"/>
                                <Setter TargetName="PasswordInputTopEdge" Property="Opacity" Value="0.18"/>
                                <Setter TargetName="PasswordInputBottomRim" Property="Opacity" Value="0.06"/>
                                <Setter Property="Effect" Value="{StaticResource GlassButtonShadowHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PasswordInputBorder" Property="Opacity" Value="0.55"/>
                                <Setter Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer Focusable="False"
                                          Background="Transparent"
                                          HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                          VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
                                          CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}"
                                          Padding="0">
                                <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LiquidGlassComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#EAF4FF"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ComboBoxItemBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0.65"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ComboBoxItemBorder" Property="Background" Value="#241A2631"/>
                                <Setter TargetName="ComboBoxItemBorder" Property="BorderBrush" Value="#18FFFFFF"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ComboBoxItemBorder" Property="Background" Value="#321D2A35"/>
                                <Setter TargetName="ComboBoxItemBorder" Property="BorderBrush" Value="#24FFFFFF"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBoxItemBorder" Property="Opacity" Value="0.55"/>
                                <Setter Property="Foreground" Value="#90A5B9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LiquidGlassComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource GlassButtonBackgroundBrush}"/>
            <Setter Property="Foreground" Value="#F7FBFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource GlassButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0.65"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect" Value="{StaticResource GlassButtonShadow}"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource LiquidGlassComboBoxItemStyle}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBoxBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12"/>
                            <Border x:Name="ComboBoxStableTint"
                                    Margin="1"
                                    IsHitTestVisible="False"
                                    CornerRadius="11"
                                    Background="{StaticResource StableDayControlSurfaceBrush}"/>
                            <Border x:Name="ComboBoxShine"
                                    Margin="1"
                                    IsHitTestVisible="False"
                                    CornerRadius="11"
                                    Background="{StaticResource GlassButtonShineBrush}"
                                    Opacity="0.03"/>
                            <Border x:Name="ComboBoxLens"
                                    Margin="1"
                                    IsHitTestVisible="False"
                                    CornerRadius="11"
                                    Background="{StaticResource GlassButtonLensBrush}"
                                    Opacity="0.12"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <SkewTransform AngleX="-7"/>
                                </Border.RenderTransform>
                            </Border>
                            <Border x:Name="ComboBoxRefraction"
                                    Margin="1"
                                    IsHitTestVisible="False"
                                    CornerRadius="11"
                                    Background="{StaticResource GlassButtonRefractionBrush}"
                                    Opacity="0.09"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1.08" ScaleY="1.03"/>
                                </Border.RenderTransform>
                            </Border>
                            <Border x:Name="ComboBoxShade"
                                    Margin="1"
                                    IsHitTestVisible="False"
                                    CornerRadius="11"
                                    Background="{StaticResource GlassButtonInnerShadeBrush}"/>
                            <Border x:Name="ComboBoxReflection"
                                    Margin="1"
                                    IsHitTestVisible="False"
                                    CornerRadius="11"
                                    Background="{StaticResource GlassButtonReflectionBrush}"
                                    Opacity="0.008"/>
                            <Border x:Name="ComboBoxTopEdge"
                                    Margin="1"
                                    IsHitTestVisible="False"
                                    CornerRadius="11"
                                    BorderThickness="0.5"
                                    BorderBrush="{StaticResource GlassButtonTopEdgeBrush}"
                                    Opacity="0.08"/>
                            <Border x:Name="ComboBoxBottomRim"
                                    Margin="2"
                                    IsHitTestVisible="False"
                                    CornerRadius="9"
                                    BorderThickness="0.5"
                                    BorderBrush="{StaticResource GlassButtonBottomRimBrush}"
                                    Opacity="0.04"/>
                            <Grid Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter x:Name="ComboBoxContentPresenter"
                                                  Grid.Column="0"
                                                  Margin="0,0,10,0"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  RecognizesAccessKey="True"/>
                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="12"
                                           Foreground="#E8E0CF"
                                           Text="&#xE70D;"/>
                            </Grid>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   HorizontalOffset="0"
                                   VerticalOffset="0"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   PopupAnimation="Slide"
                                   Focusable="False">
                                <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="ComboBoxPopupBorder"
                                            Margin="0,6,0,0"
                                            Padding="6"
                                            CornerRadius="8"
                                            Background="#D61A2631"
                                            BorderBrush="#24FFFFFF"
                                            BorderThickness="0.65"
                                            Effect="{StaticResource GlassButtonShadowHover}">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <ScrollViewer.Background>
                                                <SolidColorBrush Color="Transparent"/>
                                            </ScrollViewer.Background>
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBoxBorder" Property="BorderBrush" Value="{StaticResource GlassButtonBorderHoverBrush}"/>
                                <Setter TargetName="ComboBoxStableTint" Property="Background" Value="{StaticResource StableDayControlSurfaceHoverBrush}"/>
                                <Setter TargetName="ComboBoxLens" Property="Opacity" Value="0.18"/>
                                <Setter TargetName="ComboBoxRefraction" Property="Opacity" Value="0.13"/>
                                <Setter TargetName="ComboBoxTopEdge" Property="Opacity" Value="0.14"/>
                                <Setter TargetName="ComboBoxBottomRim" Property="Opacity" Value="0.05"/>
                                <Setter Property="Effect" Value="{StaticResource GlassButtonShadowHover}"/>
                            </Trigger>
