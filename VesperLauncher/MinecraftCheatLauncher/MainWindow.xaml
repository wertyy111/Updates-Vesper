                                                                <Setter TargetName="LeftSegment" Property="Opacity" Value="0"/>
                                                                <Setter TargetName="RightSegment" Property="Opacity" Value="1"/>
                                                                <Setter TargetName="LeftSegmentText" Property="Foreground" Value="#9EA7B2"/>
                                                                <Setter TargetName="RightSegmentText" Property="Foreground" Value="#FFFFFF"/>
                                                            </Trigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter TargetName="ToggleBorder" Property="Opacity" Value="0.56"/>
