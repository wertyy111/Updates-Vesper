    <Grid Background="#0A1118">
        <Border x:Name="RootChromeBorder"
                Margin="0"
                Background="#0A1118"
                BorderBrush="#2D343D"
                BorderThickness="1,1,0,1"
                Padding="0"
                CornerRadius="12"
                ClipToBounds="True"
                SnapsToDevicePixels="True">
            <Border x:Name="ContentHostBorder"
                    Margin="0"
                    Background="Transparent"
                    CornerRadius="11"
                    ClipToBounds="True">
                <Grid x:Name="WindowContentGrid" ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Image x:Name="BackgroundPhoto"
                       Grid.RowSpan="2"
                       Visibility="Collapsed"
                       Stretch="UniformToFill"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       SnapsToDevicePixels="True"
                       IsHitTestVisible="False"/>

                <Grid x:Name="ProceduralBackground" Grid.RowSpan="2" IsHitTestVisible="False">
                    <Rectangle Fill="{StaticResource NightBaseBrush}"/>
                    <Rectangle Fill="{StaticResource MoonGlowBrush}" Opacity="0.55"/>

                    <Rectangle VerticalAlignment="Top" Height="270" Opacity="0.28">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00000000" Offset="0"/>
                                <GradientStop Color="#3A3B8ECB" Offset="0.2"/>
                                <GradientStop Color="#0E70B1D8" Offset="0.33"/>
                                <GradientStop Color="#2F3A8ECB" Offset="0.52"/>
                                <GradientStop Color="#0B70B1D8" Offset="0.68"/>
                                <GradientStop Color="#243A8ECB" Offset="0.82"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <Rectangle Fill="#76080604"/>
                    <Rectangle Fill="{StaticResource VignetteBrush}" Opacity="0.88"/>
                </Grid>

                <Border x:Name="TitleBarBorder"
                        Grid.Row="0"
                        Background="Transparent"
                        BorderBrush="#181818"
                        BorderThickness="0,0,0,1"
                        CornerRadius="0"
                        MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                    <DockPanel Margin="12,0,8,0" LastChildFill="False">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="TopLeftLogoBorder"
                                    Width="28"
                                    Height="28"
                                    CornerRadius="7"
                                    BorderBrush="#30FFFFFF"
                                    BorderThickness="0"
                                    Background="#00000000">
                                <Image x:Name="TopLeftLogoImage"
                                       Margin="2"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       SnapsToDevicePixels="True"/>
                            </Border>
                            <TextBlock Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Text="Vesper Launcher"/>
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
