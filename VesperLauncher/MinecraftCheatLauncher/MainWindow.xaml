                                        <SolidColorBrush x:Key="LauncherSettingsTextBrush" Color="#F4F8FB"/>
                                        <SolidColorBrush x:Key="LauncherSettingsMutedTextBrush" Color="#C9D5DF"/>
                                        <SolidColorBrush x:Key="LauncherSettingsSoftTextBrush" Color="#A8B5C0"/>
                                        <SolidColorBrush x:Key="LauncherSettingsAccentBrush" Color="#DDE7F2"/>
