                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="SettingsComboBoxBorder" Property="BorderBrush" Value="{StaticResource GlassButtonBorderHoverBrush}"/>
                                                                <Setter TargetName="SettingsComboBoxStableTint" Property="Background" Value="{StaticResource StableDayControlSurfaceHoverBrush}"/>
                                                                <Setter TargetName="SettingsComboBoxLens" Property="Opacity" Value="0.18"/>
                                                                <Setter TargetName="SettingsComboBoxRefraction" Property="Opacity" Value="0.13"/>
                                                                <Setter TargetName="SettingsComboBoxTopEdge" Property="Opacity" Value="0.14"/>
                                                                <Setter TargetName="SettingsComboBoxBottomRim" Property="Opacity" Value="0.05"/>
                                                                <Setter Property="Effect" Value="{StaticResource GlassButtonShadowHover}"/>
                                                            </Trigger>
                                                            <Trigger Property="IsDropDownOpen" Value="True">
                                                                <Setter TargetName="SettingsComboBoxBorder" Property="BorderBrush" Value="{StaticResource GlassButtonBorderHoverBrush}"/>
                                                                <Setter TargetName="SettingsComboBoxStableTint" Property="Background" Value="{StaticResource StableDayControlSurfaceHoverBrush}"/>
                                                                <Setter TargetName="SettingsComboBoxLens" Property="Opacity" Value="0.2"/>
                                                                <Setter TargetName="SettingsComboBoxRefraction" Property="Opacity" Value="0.15"/>
                                                                <Setter TargetName="SettingsComboBoxTopEdge" Property="Opacity" Value="0.16"/>
                                                                <Setter TargetName="SettingsComboBoxBottomRim" Property="Opacity" Value="0.06"/>
