                                                                    Margin="1"
                                                                    IsHitTestVisible="False"
                                                                    CornerRadius="{StaticResource LauncherSettingsControlInnerCornerRadius}"
                                                                    Background="{StaticResource StableDayControlSurfaceBrush}"/>
                                                            <Border x:Name="SettingsInputShine"
                                                                    Margin="1"
                                                                    IsHitTestVisible="False"
                                                                    CornerRadius="{StaticResource LauncherSettingsControlInnerCornerRadius}"
                                                                    Background="{StaticResource GlassButtonShineBrush}"
                                                                    Opacity="0.03"/>
                                                            <Border x:Name="SettingsInputLens"
                                                                    Margin="1"
                                                                    IsHitTestVisible="False"
                                                                    CornerRadius="{StaticResource LauncherSettingsControlInnerCornerRadius}"
                                                                    Background="{StaticResource GlassButtonLensBrush}"
                                                                    Opacity="0.12"
                                                                    RenderTransformOrigin="0.5,0.5">
                                                                <Border.RenderTransform>
                                                                    <SkewTransform AngleX="-7"/>
                                                                </Border.RenderTransform>
                                                            </Border>
                                                            <Border x:Name="SettingsInputRefraction"
                                                                    Margin="1"
                                                                    IsHitTestVisible="False"
                                                                    CornerRadius="{StaticResource LauncherSettingsControlInnerCornerRadius}"
                                                                    Background="{StaticResource GlassButtonRefractionBrush}"
                                                                    Opacity="0.09"
                                                                    RenderTransformOrigin="0.5,0.5">
                                                                <Border.RenderTransform>
                                                                    <ScaleTransform ScaleX="1.08" ScaleY="1.03"/>
                                                                </Border.RenderTransform>
                                                            </Border>
                                                            <Border x:Name="SettingsInputShade"
                                                                    Margin="1"
                                                                    IsHitTestVisible="False"
                                                                    CornerRadius="{StaticResource LauncherSettingsControlInnerCornerRadius}"
                                                                    Background="{StaticResource GlassButtonInnerShadeBrush}"/>
                                                            <Border x:Name="SettingsInputReflection"
                                                                    Margin="1"
                                                                    IsHitTestVisible="False"
                                                                    CornerRadius="{StaticResource LauncherSettingsControlInnerCornerRadius}"
                                                                    Background="{StaticResource GlassButtonReflectionBrush}"
                                                                    Opacity="0.008"/>
                                                            <Border x:Name="SettingsInputTopEdge"
                                                                    Margin="1"
                                                                    IsHitTestVisible="False"
                                                                    CornerRadius="{StaticResource LauncherSettingsControlInnerCornerRadius}"
                                                                    BorderThickness="0.5"
                                                                    BorderBrush="{StaticResource GlassButtonTopEdgeBrush}"
                                                                    Opacity="0.08"/>
                                                            <Border x:Name="SettingsInputBottomRim"
                                                                    Margin="2"
                                                                    IsHitTestVisible="False"
                                                                    CornerRadius="{StaticResource LauncherSettingsControlRimCornerRadius}"
                                                                    BorderThickness="0.5"
                                                                    BorderBrush="{StaticResource GlassButtonBottomRimBrush}"
                                                                    Opacity="0.04"/>
                                                            <ScrollViewer x:Name="PART_ContentHost"
