                                <StackPanel x:Name="SettingsSectionPanel" Visibility="Collapsed">
                                    <StackPanel.Resources>
                                        <LinearGradientBrush x:Key="LauncherSettingsShellBrush" StartPoint="0,0" EndPoint="1,1">
