<Window x:Class="VesperLauncher.StartupUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vesper Launcher"
        Icon="Assets/vesper-app.ico"
        Width="388"
        Height="196"
        MinWidth="388"
        MaxWidth="388"
        MinHeight="196"
        MaxHeight="196"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="True"
        Topmost="True"
        WindowStartupLocation="CenterScreen">
    <Border CornerRadius="20"
            Background="#F20B1620"
            BorderBrush="#AA3A556B"
            BorderThickness="1"
            Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Vesper Launcher"
                           FontFamily="Segoe UI"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="White" />
                <TextBlock Text="Проверка обновлений перед запуском"
                           Margin="0,4,0,0"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           Foreground="#B7D1DF" />
            </StackPanel>

            <TextBlock x:Name="StatusTextBlock"
                       Grid.Row="1"
                       Margin="0,18,0,0"
                       FontFamily="Segoe UI"
                       FontSize="13"
                       Foreground="#EAF6FF"
                       TextWrapping="Wrap"
                       Text="Проверяем обновления..." />

            <TextBlock x:Name="DetailTextBlock"
                       Grid.Row="2"
                       Margin="0,8,0,0"
                       FontFamily="Segoe UI"
                       FontSize="11"
                       Foreground="#90B0C2"
                       TextWrapping="Wrap"
                       Text="Подключаемся к серверу обновлений..." />

            <StackPanel Grid.Row="3" Margin="0,16,0,0">
                <Border CornerRadius="999"
                        Background="#2AFFFFFF"
                        Height="10">
                    <ProgressBar x:Name="StatusProgressBar"
                                 Height="10"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0"
                                 IsIndeterminate="True"
                                 Foreground="#8ED8FF"
                                 Background="Transparent"
                                 BorderThickness="0" />
                </Border>

                <TextBlock x:Name="ProgressTextBlock"
                           Margin="0,10,0,0"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Foreground="#90B0C2"
                           Text="Подготовка..." />
            </StackPanel>
        </Grid>
    </Border>
</Window>

